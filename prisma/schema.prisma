generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Job {
  id          String   @id @default(cuid())
  title       String
  company     String
  description String   @db.Text
  location    String
  filiere     String
  niveau      String
  region      String
  url         String
  source      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([filiere])
  @@index([niveau])
  @@index([region])
}