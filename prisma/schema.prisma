generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Job {
  id           String   @id @default(cuid())
  title        String
  company      String
  description  String   @db.Text
  location     String
  filiere      String
  niveau       String
  region       String
  contractType String   @default("Alternance")
  url          String   @unique
  source       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([filiere])
  @@index([niveau])
  @@index([region])
  @@index([contractType])
}