generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
}

enum ScrapeStatus {
  RUNNING
  SUCCEEDED
  FAILED
}

// ─── Job ──────────────────────────────────────────────────────────────────────

model Job {
  id           String   @id @default(cuid())
  title        String
  company      String
  description  String   @db.Text
  location     String
  filiere      String
  niveau       String
  region       String
  contractType String   @default("Alternance")
  url          String   @unique
  source       String
  isApproved   Boolean  @default(true)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Multi-source tracking
  sources     String[]
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())

  // Enrichment
  salary       String?
  memo         String?
  tags         String[]
  companyLogo  String?
  applyUrl     String?
  postedAt     DateTime?
  expiresAt    DateTime?
  taskId       String?
  apifyActorId String?
  rawData      Json?

  savedBy      SavedJob[]
  applications JobApplication[]

  // Composite indexes for common filter combinations
  @@index([isActive, createdAt])
  @@index([isActive, isApproved])
  @@index([filiere, isActive])
  @@index([contractType, isActive])
  @@index([region, isActive])
  @@index([niveau, isActive])
  @@index([source])
}

// ─── ScrapeRun ────────────────────────────────────────────────────────────────

model ScrapeRun {
  id         String       @id @default(cuid())
  apifyRunId String?      @unique
  school     String
  source     String
  status     ScrapeStatus @default(RUNNING)

  jobsFound    Int @default(0)
  jobsFiltered Int @default(0)
  jobsSaved    Int @default(0)
  duplicates   Int @default(0)

  keywords    String?
  error       String?
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  runTime     Int?

  createdAt DateTime @default(now())

  @@index([school, startedAt])
  @@index([status])
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  password      String?
  name          String?
  image         String?

  // School info
  school         String?
  educationLevel String?
  graduationYear Int?
  specialization String?

  // Contact
  phone     String?
  linkedIn  String?
  portfolio String?

  // Preferences (stored as JSON)
  preferences Json?

  // CV
  cvUrl        String?
  cvFileName   String?
  cvUploadedAt DateTime?

  // Role
  role UserRole @default(USER)

  accounts     Account[]
  sessions     Session[]
  savedJobs    SavedJob[]
  applications JobApplication[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([createdAt])
}

// ─── NextAuth ─────────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── HubSpot whitelist ────────────────────────────────────────────────────────

model StudentWhitelist {
  id               String   @id @default(cuid())
  email            String   @unique
  school           String?
  hubspotContactId String?
  verifiedAt       DateTime @default(now())
  expiresAt        DateTime
}

// ─── User activity ────────────────────────────────────────────────────────────

model JobApplication {
  id        String   @id @default(cuid())
  userId    String
  jobId     String
  appliedAt DateTime @default(now())
  status    String   @default("applied")
  notes     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([userId])
  @@index([jobId])
  @@index([status])
}

model SavedJob {
  id      String   @id @default(cuid())
  userId  String
  jobId   String
  savedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([userId])
  @@index([jobId])
}

// ─── Feedback / Bug reports ───────────────────────────────────────────────────

model Feedback {
  id        String   @id @default(cuid())
  type      String   // "bug" | "suggestion"
  message   String   @db.Text
  email     String?
  userId    String?
  page      String?
  userAgent String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([type])
  @@index([isRead])
  @@index([createdAt])
}
